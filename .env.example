APP_NAME="Zova Sport"
APP_ENV=local
APP_KEY=base64:8x7mWn+EG9RdjgPT2wE7vsEsbySeoqxIp9otCDXR2Os=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jindo_vsport
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Order confirmation/status emails are queued (ShouldQueue). The `jobs` table
# migration is included, so `database` works out of the box — just run a
# worker in production: php artisan queue:work --tries=3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Production example (replace the MAIL_MAILER=log block above):
# MAIL_MAILER=smtp
# MAIL_SCHEME=smtps
# MAIL_HOST=smtp.your-provider.com
# MAIL_PORT=465
# MAIL_USERNAME=your-smtp-username
# MAIL_PASSWORD=your-smtp-password
# MAIL_FROM_ADDRESS="orders@yourdomain.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@vsport.local
ADMIN_PASSWORD=password

SUPABASE_STORAGE_KEY=
SUPABASE_STORAGE_SECRET=
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_BUCKET=product-images
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_ENDPOINT=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Production: pk_live_ / sk_live_ keys; webhook URL = {APP_URL}/stripe/webhook (event: payment_intent.succeeded)
# Cancelling a confirmed Stripe order auto-refunds via this same secret key.

# A variant is "low stock" when quantity - reserved_quantity <= this number.
# Alerted daily at 08:00 to the store contact email (admin/settings), deduped
# per SKU for 72h. See `inventory:check-low-stock`.
LOW_STOCK_THRESHOLD=5

# Optional: Sentry error monitoring (https://sentry.io)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# One-off deploy ops (cPanel without shell). Pass ?token= or X-Ops-Token header.
# GET /ops/storage-link?token=...
# GET /ops/clear-cache?token=...            — clear config/route/view/app cache
# GET /ops/clear-cache?token=...&warm=1     — clear then rebuild caches (production)
OPS_TOKEN=EG9RdjgPT2wE7vsEsbySeoqxIp9otCDXR2Os
